// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Platform user, keyed by Clerk user id. `credits` is THE credit balance the
// whole platform shares — bookings will reuse this same column/transaction
// pattern (project_brain.md §4: do NOT build a parallel credit system).
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  credits   Int      @default(1) // Free plan = 1 credit (see PLANS in lib/data.js)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI System Design Reviewer — project_brain.md §4
model DesignReview {
  id             String       @id @default(cuid())
  userId         String // Clerk user id
  status         ReviewStatus @default(PROCESSING)
  imageUrl       String? // Blob URL; null if mermaid-input
  inputMermaid   String? // if user pasted code instead of image
  context        Json // { systemType, scaleTarget, focusAreas[] }
  result         Json? // full DesignReview JSON from AI
  summaryPreview String? // fast first-impressions text, written before `result` lands
  mermaidAccurate Boolean? // thumbs feedback: "Was this reconstruction accurate?" (null = no vote)
  creditsCost    Int          @default(1)
  createdAt      DateTime     @default(now())

  @@index([userId, createdAt])
}

enum ReviewStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// Per-review observability (project_brain.md §7 — latency/cost guardrails).
model ReviewMetric {
  id              String   @id @default(cuid())
  reviewId        String
  model           String
  status          String // COMPLETED | FAILED
  latencyMs       Int
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  costEstimate    Float    @default(0) // USD
  zodParseRetries Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
}
